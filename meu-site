  <script>
    // ==== CONFIG (troca aqui para os teus dados reais) ====
    const CONFIG = {
      whatsappNumberInternational: "2380000000", // sem +, sem espaços (ex: "2389XXXXXXX")
      emailTo: "info@ventoseviagens.cv",
      phoneTel: "+2380000000"
    };

    // Apply contact links
    const phoneLink = document.getElementById("phone-link");
    const emailLink = document.getElementById("email-link");
    const whatsappQuick = document.getElementById("whatsapp-quick");
    const emailQuick = document.getElementById("email-quick");

    if (phoneLink) phoneLink.href = `tel:${CONFIG.phoneTel}`;
    if (phoneLink) phoneLink.textContent = CONFIG.phoneTel.replace("+", "+").replace(/(\d{3})(\d{3})(\d{4,})/, "+$1 $2 $3");
    if (emailLink) emailLink.href = `mailto:${CONFIG.emailTo}`;
    if (emailLink) emailLink.textContent = CONFIG.emailTo;
    if (emailQuick) emailQuick.href = `mailto:${CONFIG.emailTo}?subject=${encodeURIComponent("Pedido de informações - Ventos e Viagens")}`;

    // Mobile menu
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileClose = document.getElementById('mobile-close');

    const openMenu = () => mobileMenu && mobileMenu.classList.remove('hidden');
    const closeMenu = () => mobileMenu && mobileMenu.classList.add('hidden');

    if (mobileMenuBtn && mobileMenu) mobileMenuBtn.addEventListener('click', openMenu);
    if (mobileClose && mobileMenu) mobileClose.addEventListener('click', closeMenu);

    if (mobileMenu) {
      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });
    }

    // Navbar scroll effect
    const navbar = document.getElementById('navbar');
    const onScroll = () => {
      if (!navbar) return;
      if (window.scrollY > 40) {
        navbar.classList.add('bg-sky-900/95', 'backdrop-blur-lg', 'shadow-lg');
      } else {
        navbar.classList.remove('bg-sky-900/95', 'backdrop-blur-lg', 'shadow-lg');
      }
    };
    window.addEventListener('scroll', onScroll);
    onScroll();

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        const href = this.getAttribute('href');
        const target = href ? document.querySelector(href) : null;
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // WhatsApp helper
    function buildWhatsAppUrl(text) {
      const base = `https://wa.me/${CONFIG.whatsappNumberInternational}`;
      return `${base}?text=${encodeURIComponent(text)}`;
    }

    // Quick WhatsApp button
    if (whatsappQuick) {
      whatsappQuick.addEventListener("click", (e) => {
        e.preventDefault();
        const msg = "Olá! Gostaria de informações sobre tours/viagens em Cabo Verde 😊";
        window.open(buildWhatsAppUrl(msg), "_blank");
      });
    }

    // Contact form (opens WhatsApp + prepares email)
    const contactForm = document.getElementById('contact-form');
    const formSuccess = document.getElementById('form-success');

    if (contactForm) {
      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();

        const nome = document.getElementById('nome')?.value?.trim() || "";
        const email = document.getElementById('email')?.value?.trim() || "";
        const destino = document.getElementById('destino')?.value || "";
        const mensagem = document.getElementById('mensagem')?.value?.trim() || "";

        const destinoLabel = destino ? destino : "Não especificado";

        const text =
`Olá! 👋
Sou ${nome}.
Email: ${email}
Destino: ${destinoLabel}

Mensagem:
${mensagem}

(Enviado pelo site Ventos e Viagens)`;

        // open WhatsApp
        window.open(buildWhatsAppUrl(text), "_blank");

        // open mailto (some browsers may block popups; still useful)
        const subject = "Pedido de informações - Ventos e Viagens";
        const body = text;
        window.location.href = `mailto:${CONFIG.emailTo}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

        // UI feedback
        contactForm.classList.add('hidden');
        if (formSuccess) formSuccess.classList.remove('hidden');

        setTimeout(() => {
          contactForm.reset();
          contactForm.classList.remove('hidden');
          if (formSuccess) formSuccess.classList.add('hidden');
        }, 3500);
      });
    }
  </script>
